# Telegram bot token (required)
TG_BOT_TOKEN=
# Telegram admin user ID (required)
TG_ADMIN_ID=
# Client configuration endpoint URL (required)
CLIENT_CONFIG_ENDPOINT=
# Database file location (optional, default: ./db/vpn_signaling_server.db)
DB_LOCATION=./db/vpn_signaling_server.db
# Log level (optional, default: info)
LOG_LEVEL=info
# Disable timestamp in logs (optional, default: false)
LOG_DISABLE_TIMESTAMP=false


# Sing-Box Reality private key (required for config generation)
SING_BOX_PRIVATE_KEY=
# Sing-Box Reality short ID (required for config generation)
SING_BOX_SHORT_ID=
# Sing-Box server hostname for clients
SING_BOX_SERVER_NAME=google.com
# Sing-Box server port
SING_BOX_SERVER_PORT=443
