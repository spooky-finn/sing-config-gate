{
	"name": "vpn_signaling_server",
	"version": "1.0.0",
	"module": "src/main.ts",
	"scripts": {
		"fmt": "biome format --write",
		"lint": "biome lint --write",
		"fix": "biome check --write",
		"start": "bun run dist/src/main.js",
		"dev": "bun --watch src/main.ts",
		"check": "tsc -p tsconfig.json --noEmit",
		"build": "tspc -p tsconfig.json",
		"test": "bun test",
		"deploy": "bun run dist/deploy.js",
		"migration:create": "bun run dist/src/utils/create-migration.js",
		"prepare": "ts-patch install"
	},
	"imports": {
		"#root/*": "./src/*"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spooky-finn/vpn_signaling_server.git"
	},
	"author": "",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/spooky-finn/vpn_signaling_server/issues"
	},
	"homepage": "https://github.com/spooky-finn/vpn_signaling_server#readme",
	"description": "",
	"dependencies": {
		"commander": "^14.0.0",
		"kysely": "^0.28.3",
		"kysely-bun-sqlite": "0.4.0",
		"node-telegram-bot-api": "^0.67.0",
		"pino": "^10.3.1",
		"pino-pretty": "^13.0.0",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.11",
		"@types/node-telegram-bot-api": "^0.64.9",
		"bun-types": "1.3.10",
		"ts-patch": "3.3.0",
		"typescript": "^5.9.3"
	}
}
